{
  "name": "xranalizer",
  "version": "1.0.0",
  "private": true,
  "description": "Webhook request analyzer — capture, inspect and replay HTTP requests in real time",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm-run-all --parallel build:api build:web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "start:api": "npm run start:prod --workspace=apps/api",
    "start:web": "npm run start --workspace=apps/web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
