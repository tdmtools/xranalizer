# ========================================
# API (apps/api/.env)
# ========================================
# Local: 3001. On Heroku, leave PORT unset — Heroku injects it.
API_PORT=3001
API_HOST=0.0.0.0

# CORS: CORS_ALLOW_ALL=true → any origin. Otherwise CORS_ORIGIN = comma list (Vercel URL, etc.)
CORS_ALLOW_ALL=true
# CORS_ORIGIN=https://xranalizer.vercel.app
# CORS_ORIGIN=http://localhost:3000,https://xranalizer.vercel.app
CORS_ORIGIN=

# Mongo connection. On Heroku, point to a cloud Mongo (Atlas/etc.).
# Either MONGO_URI or MONGODB_URI; use the same connection string as in Atlas (Drivers).
MONGO_URI=mongodb://root:password@localhost:27017/
# MONGODB_URI=...   # optional alias (Heroku add-ons / copy-paste from tutorials)
DATA_BASE_NAME=xranalizer

MAX_BODY_SIZE=10mb

# ========================================
# WEB (apps/web/.env.local)
# ========================================
PORT=3000
# In production set both to the Heroku API URL, e.g. https://xranalizer-api.herokuapp.com
# No trailing slash (otherwise requests become //api/... and return 404).
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
